{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Flash ELF (OpenOCD)",
            "type": "shell",
            "command": "openocd",
            "args": [
                "-f",
                "openocd.cfg",
                "-c",
                "program build/MotorController.elf verify reset exit"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [ ],
            "group": "build"
        }
    ]
}
